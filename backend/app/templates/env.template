DRIVER=~fastapi+~websockets
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=INFO
ONEBOT_ACCESS_TOKEN=
# 无人值守容器内禁用 nonebot-plugin-orm 启动时的交互式迁移确认。某些插件依赖
# nonebot-plugin-orm，它启动时会做一次「目标数据库未更新到最新迁移? [y/N]」的
# 交互确认；本容器跑在 supervisord 下没有 stdin，确认会被中止导致 NoneBot 退出。
# 设为 false 时插件改为启动时自动同步数据库模式（建缺失的表），无需交互。
ALEMBIC_STARTUP_CHECK=false
# plugin configs appended here
